{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'cd \"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\" && exec .agents/hooks/_py.sh .agents/hooks/agent_guard_adapter.py codex'",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
