# project-init runtime artifacts
# NB: do NOT ignore .codex/ wholesale — the codex overlay commits
# .codex/hooks.json and .codex/config.toml as project config (2026-07 review).
.claude/scheduled_tasks.lock
.claude/.session_setup_stamp
.claude/settings.local.json
.claude/memory/.cache/
.claude/logs/
.claude/.local/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
.pytest_cache/
.ruff_cache/

# OS / editor
.DS_Store
*.swp
# .vscode is personal, except a generated MCP config meant to be shared (PI-366).
.vscode/*
!.vscode/mcp.json
.idea/

# Secrets
.env
.env.local
*.key

# machine-specific fleet definition (see fleet.yaml.example)
fleet.yaml
.coverage
