# fleet.yaml — which projects this orchestrator governs.
#
# Copy to `fleet.yaml` (gitignored — the fleet is machine-specific) and
# adjust. Without this file the orchestrator scans the parent directory of
# the current checkout (the ~/projects/<name> sibling convention).
#
# Paths may be absolute, ~-relative, or relative to this file.

# Directories scanned one level deep; anything with .claude/config.yaml counts.
roots:
  - ..

# Explicit project paths outside the roots.
projects: []
#  - ~/work/some-other-project

# Directory-name patterns (fnmatch) to skip while scanning roots.
exclude: []
#  - archive-*

# Also govern plain git repos (no .claude/config.yaml) with a minimal
# inferred descriptor: language + lint/test/run from justfile / package.json
# scripts / pyproject / Cargo.toml / go.mod conventions. Off by default.
include_plain_repos: false
